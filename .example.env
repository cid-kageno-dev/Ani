# .env example — copy to .env and fill in your values

# --- GEMINI API KEY ---
# Get one at https://aistudio.google.com/apikey
# You can add multiple keys for rotation (optional)
GOOGLE_API_KEY="AIzaSyD-YourKeyHere..."
# GOOGLE_API_KEY1="AIzaSyD-YourFirstKey..."
# GOOGLE_API_KEY2="AIzaSyD-YourSecondKey..."

# --- FIREBASE (Optional) ---
# Place your Firebase service account file at: firebase-key.json
# The app will detect it automatically — no env var needed.
# Alternatively you can still point to a custom path:
# FIREBASE_CREDENTIALS="path/to/your-key.json"

# --- POSTGRESQL ---
# Automatically provided by Replit — only needed if running locally
DATABASE_URL="postgresql://user:password@host:5432/database"
