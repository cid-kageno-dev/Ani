{
  "name": "ani",
  "version": "1.0.0",
  "description": "A smart, Portfolio AI assistant",
  "author": "Cid Kageno",
  "license": "MIT",
  "homepage": "https://github.com/cid-kageno-dev/Ani",
  "repository": {
    "type": "git",
    "url": "https://github.com/cid-kageno-dev/Ani.git"
  },
  "keywords": [
    "ai",
    "assistant",
    "portfolio",
    "gemini",
    "firebase",
    "flask",
    "python"
  ],
  "scripts": {
    "start": "python run.py",
    "dev": "python run.py",
    "test": "pytest",
    "test:cov": "pytest --cov=app --cov-report=html",
    "lint": "flake8 app config.py run.py",
    "format": "black app config.py run.py",
    "type-check": "mypy app",
    "security": "bandit -r app",
    "install-deps": "pip install -r requirements.txt",
    "install-dev": "pip install -r requirements-dev.txt",
    "clean": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true"
  },
  "engines": {
    "python": ">=3.10"
  },
  "python": {
    "version": "3.10+"
  },
  "dependencies": {
    "flask": "^2.0.0",
    "flask-cors": "^4.0.0",
    "google-genai": "latest",
    "gunicorn": "^21.0.0",
    "psycopg2-binary": "^2.9.0",
    "thefuzz": "^0.19.0",
    "firebase-admin": "^6.0.0"
  },
  "devDependencies": {
    "pytest": "^7.4.0",
    "pytest-cov": "^4.1.0",
    "pytest-flask": "^1.3.0",
    "black": "^23.7.0",
    "flake8": "^6.1.0",
    "mypy": "^1.5.0",
    "bandit": "^1.7.5",
    "safety": "^2.3.5",
    "ipython": "^8.15.0"
  },
  "environment": {
    "production": {
      "FLASK_ENV": "production",
      "FLASK_DEBUG": "false"
    },
    "development": {
      "FLASK_ENV": "development",
      "FLASK_DEBUG": "true"
    }
  },
  "deployment": {
    "docker": true,
    "heroku": true,
    "replit": true
  },
  "features": {
    "ai_chat": true,
    "github_integration": true,
    "monitoring": true,
    "database_cache": true
  },
  "api": {
    "version": "1.0",
    "endpoints": [
      "/",
      "/api/chat",
      "/api/history",
      "/api/stats",
      "/api/github",
      "/api/health",
      "/api/cache/status",
      "/api/cache/clear"
    ]
  },
  "database": {
    "primary": "firebase",
    "fallback": "postgresql",
    "caching": {
      "enabled": true,
      "ttl_seconds": 300
    }
  },
  "contributors": [
    {
      "name": "Cid Kageno",
      "url": "https://github.com/cid-kageno-dev"
    }
  ],
  "bugs": {
    "url": "https://github.com/cid-kageno-dev/Ani/issues"
  }
}
