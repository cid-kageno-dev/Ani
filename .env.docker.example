# ========================================
# DOCKER ENVIRONMENT
# ========================================
# For running Ani in Docker containers

# Google Gemini AI
GOOGLE_API_KEY1="AIzaSyD-your-gemini-api-key-here"

# Database Backend
DATABASE_BACKEND="auto"

# Firebase Firestore (DOCKER - use environment variable)
FIREBASE_CREDENTIALS=""
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project",...}'
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_DATABASE_URL="https://your-project.firebaseio.com"
FIREBASE_COLLECTION="chat_interactions"

# PostgreSQL (if using with Docker Compose)
DATABASE_URL="postgresql://postgres:password@postgres:5432/ani_db"

# GitHub
GITHUB_USERNAME="cid-kageno-dev"
GITHUB_CACHE_TTL=300

# Application
FLASK_DEBUG=false
LOG_LEVEL="INFO"
PORT=5000

# Notes:
# • Set FIREBASE_SERVICE_ACCOUNT_JSON as environment variable, not file
# • Place the full JSON on a single line in Dockerfile or docker-compose.yml
# • Use docker-compose to manage multiple containers (app + postgres)
