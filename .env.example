# ─────────────────────────────────────────────
#  Ani — AI Assistant  |  example.env
#  Copy this file to .env and fill in values.
#  Never commit your real .env to version control.
# ─────────────────────────────────────────────

# ── Gemini AI ────────────────────────────────
# At least one key is required. Add more for key rotation (KEY2, KEY3, …).
# Get keys at: https://aistudio.google.com/apikey
GOOGLE_API_KEY1=your-gemini-api-key-here
# GOOGLE_API_KEY2=your-second-key-here

# Model settings (optional — defaults shown)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMP=0.55
GEMINI_MAX_TOKENS=512

# ── Firebase (primary DB backend) ────────────
# Provide your Firebase project credentials.
# Console: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_COLLECTION=chat_interactions

# Paste the full JSON contents of your service account key (one line).
# Download from Firebase Console → Project Settings → Service Accounts.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Alternative: path to a local service account key file (dev only).
# FIREBASE_CREDENTIALS=firebase-key.json

# ── PostgreSQL — Primary (Replit built-in) ───
# Managed automatically by Replit. Do NOT set this manually in Replit.
# For local dev, point to your own Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/ani_db

# ── PostgreSQL — Mirror (Render) ─────────────
# External Render Postgres. Use the "External Database URL" from the
# Render dashboard → your DB → Connect tab.
RENDER_DATABASE_URL=postgresql://user:password@host.oregon-postgres.render.com/dbname

# Which backend to use: auto | firebase | postgres (default: auto)
# "auto" prefers Firebase when FIREBASE_PROJECT_ID is set, else Postgres.
DATABASE_BACKEND=auto

# ── GitHub context ───────────────────────────
# GitHub username whose profile/repos are fetched for AI context.
GITHUB_USERNAME=cid-kageno-dev
# How long (seconds) to cache GitHub data in memory (default: 300)
GITHUB_CACHE_TTL=300

# ── App settings ─────────────────────────────
FLASK_DEBUG=true
LOG_LEVEL=INFO
