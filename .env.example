# ════════════════════════════════════════════════════════════════
#  Ani — AI Assistant  |  .env.example
#  Copy this file to .env and fill in your values.
#  In Replit: add these as Secrets (not as a .env file).
# ════════════════════════════════════════════════════════════════


# ── IDENTITY ─────────────────────────────────────────────────────
# These are the only values you MUST change to make this your own.

# Name of the AI assistant persona (shown in the UI)
ASSISTANT_NAME=Ani

# Full name of the person the assistant represents
OWNER_NAME=Your Name

# Your organisation or team name (optional — leave blank to hide)
ORG_NAME=Your Org

# Contact details included in the AI's context (all optional)
OWNER_EMAIL=you@example.com
OWNER_WEBSITE=https://yoursite.com
OWNER_FACEBOOK=https://facebook.com/yourprofile

# Short tagline shown in the sidebar panel
OWNER_TAGLINE=A fast, smart portfolio assistant — live GitHub context, AI responses, and cached fallback knowledge.

# Footer note at the bottom of the sidebar
OWNER_FOOTER_NOTE=Designed for recruiters, collaborators, and anyone curious about the work.

# Comma-separated list of suggested questions shown as quick-ask chips
CHAT_SUGGESTIONS=What projects have you built?,What's your tech stack?,How can I contact you?,Show your recent GitHub work


# ── GITHUB ───────────────────────────────────────────────────────
# GitHub handle whose profile, repos, and README are fetched live
GITHUB_USERNAME=your-github-username

# How long (seconds) to cache the GitHub API response (default: 300)
GITHUB_CACHE_TTL=300


# ── GEMINI AI ────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
# Add multiple keys for automatic rotation on quota exhaustion.
GOOGLE_API_KEY1=your-gemini-api-key-here
# GOOGLE_API_KEY2=second-key-for-rotation

# Model to use (gemini-2.5-flash is fast and free-tier friendly)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMP=0.55
GEMINI_MAX_TOKENS=512


# ── FIREBASE (primary database — recommended) ─────────────────────
# Create a project at https://console.firebase.google.com/
# Download the service account JSON and paste the entire contents here.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Your Firebase project ID
FIREBASE_PROJECT_ID=your-project-id

# Firebase Realtime Database URL (required if using Realtime DB)
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Firestore collection name for storing chat interactions
FIREBASE_COLLECTION=chat_interactions


# ── POSTGRESQL (auto-provided on Replit, optional elsewhere) ─────
# Replit provides DATABASE_URL automatically — do not override it.
# On other platforms, set this to your PostgreSQL connection string.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Which backend to use: auto | firebase | postgres (default: auto)
# "auto" prefers Firebase when FIREBASE_PROJECT_ID is set, else Postgres.
DATABASE_BACKEND=auto


# ── RENDER POSTGRESQL (optional mirror database) ──────────────────
# If set, every interaction is mirrored to this database in parallel.
# Useful for keeping a persistent copy outside Replit.
# Get a free PostgreSQL database at https://render.com/
# RENDER_DATABASE_URL=postgresql://user:password@host:5432/dbname


# ── APP ───────────────────────────────────────────────────────────
# Maximum characters allowed per user message
MAX_MESSAGE_LENGTH=1200

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable Flask debug mode (set to false in production)
FLASK_DEBUG=false
